{
  "manifest_version": 3,
  "name": "Zyrox Client for Gimkit",
  "description": "A modern hacked client / utility mod for gimkit.",
  "version": "2.3.5",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.gimkit.com/join*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js"
      ],
      "matches": [
        "https://www.gimkit.com/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "zyrox-client@gimkit.local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
